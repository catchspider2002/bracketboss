# Copy this file to `.dev.vars` (gitignored) and fill in real values for `wrangler dev`.
# For PRODUCTION, do NOT use a file — set with:  wrangler secret put NAME
TXLINE_API_KEY="your_txline_key"
# Optional — protects the /api/admin/* endpoints (seed teams, map fixtures). Use any long random string.
ADMIN_KEY="your_long_random_admin_secret"
