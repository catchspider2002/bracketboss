# Reference list of required secrets (documentation only).
# On Cloudflare: local dev -> `.dev.vars`; production -> `wrangler secret put NAME`.
# No Claude API — bracket logic and scoring are deterministic.
TXLINE_API_KEY=your_txline_key
# Optional — protects /api/admin/* (seed teams, map fixtures). Any long random string.
ADMIN_KEY=your_long_random_admin_secret
